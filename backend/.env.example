# =============================================================================
# Vibgyor Payment Gateway - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and configure with your actual values
# NEVER commit the .env file to version control

# =============================================================================
# Server Configuration
# =============================================================================

# PORT - The port number on which the backend server will listen
# Default: 3000
# Example: PORT=3000
PORT=3000

# NODE_ENV - The environment in which the application is running
# Options: 'development', 'production', 'test'
# Default: development
# In production, this enables optimizations and stricter security
NODE_ENV=development

# LOG_LEVEL - Controls the verbosity of application logs
# Options: 'error', 'warn', 'info', 'debug'
# Default: info
# Use 'debug' for detailed troubleshooting, 'error' for production
LOG_LEVEL=info

# =============================================================================
# Payment Provider Configuration
# =============================================================================

# PAYMENT_PROVIDER - Specifies which payment gateway to use
# Options: 'razorpay' or 'pinelabs'
# REQUIRED: Must be set to one of the supported providers
# The application will fail to start if this is not set or invalid
PAYMENT_PROVIDER=razorpay

# =============================================================================
# Razorpay Configuration
# =============================================================================
# Required only if PAYMENT_PROVIDER=razorpay
# Obtain these credentials from your Razorpay dashboard at https://dashboard.razorpay.com

# RAZORPAY_KEY_ID - Your Razorpay API Key ID (public key)
# This is safe to expose in frontend code
# Example: rzp_test_1234567890abcd or rzp_live_1234567890abcd
RAZORPAY_KEY_ID=rzp_test_xxxxx

# RAZORPAY_KEY_SECRET - Your Razorpay API Key Secret (private key)
# CRITICAL: Keep this secret secure, never expose in frontend code
# Used for payment verification and webhook signature validation
RAZORPAY_KEY_SECRET=xxxxx

# =============================================================================
# PineLabs Configuration
# =============================================================================
# Required only if PAYMENT_PROVIDER=pinelabs
# Obtain these credentials from your PineLabs merchant account

# PINELABS_MERCHANT_ID - Your PineLabs merchant identifier
# Example: 12345
PINELABS_MERCHANT_ID=xxxxx

# PINELABS_ACCESS_CODE - Your PineLabs access code for API authentication
# CRITICAL: Keep this secret secure
PINELABS_ACCESS_CODE=xxxxx

# PINELABS_SECRET_KEY - Your PineLabs secret key for signature verification
# CRITICAL: Keep this secret secure
# Used for webhook signature validation
PINELABS_SECRET_KEY=xxxxx

# PINELABS_API_URL - Optional override for PineLabs API endpoint
# Default: https://api.pluralonline.com
# MUST use HTTPS protocol for security
# Only change this if instructed by PineLabs support
# PINELABS_API_URL=https://api.pluralonline.com

# =============================================================================
# CORS Configuration
# =============================================================================

# ALLOWED_ORIGINS - Comma-separated list of allowed frontend origins
# Controls which domains can make API requests to this backend
# 
# Development: Can use '*' or specific localhost URLs
# Production: MUST be explicitly set to authorized domains only
# 
# Examples:
#   Development: ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200
#   Production: ALLOWED_ORIGINS=https://example.com,https://app.example.com
#   All origins (dev only): ALLOWED_ORIGINS=*
#
# SECURITY: In production, never use '*' - always specify exact domains
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200

# =============================================================================
# MongoDB Configuration
# =============================================================================

# MONGODB_URI - MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/database[?options]
# 
# Local Development: mongodb://localhost:27017/vibgyor-payment-gateway
# Docker: mongodb://mongo:27017/vibgyor-payment-gateway
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/vibgyor-payment-gateway
#
# SECURITY: For production, use authentication and SSL/TLS
MONGODB_URI=mongodb://localhost:27017/vibgyor-payment-gateway

# =============================================================================
# DocuSeal Configuration
# =============================================================================
# Required for e-signature functionality
# Obtain these credentials from your DocuSeal account at https://www.docuseal.co

# DOCUSEAL_API_KEY - Your DocuSeal API key for authentication
# CRITICAL: Keep this secret secure
# Example: ds_xxxxxxxxxxxxxxxxxxxxx
DOCUSEAL_API_KEY=your_docuseal_api_key_here

# DOCUSEAL_API_URL - DocuSeal API endpoint
# Default: https://api.docuseal.co
# Only change if using self-hosted DocuSeal
DOCUSEAL_API_URL=https://api.docuseal.co

# =============================================================================
# Email Configuration (Gmail SMTP)
# =============================================================================
# Required for sending payment reminder emails

# SMTP_USER - Your Gmail email address
# Example: your-email@gmail.com
# NOTE: You need to enable "App Passwords" in your Google Account
# Go to: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com

# SMTP_PASSWORD - Your Gmail App Password (NOT your regular Gmail password)
# CRITICAL: Use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
# Example: abcd efgh ijkl mnop (16 characters, spaces are optional)
SMTP_PASSWORD=your-app-password-here

# SMTP_FROM_NAME - The name that appears in the "From" field of emails
# Example: Vibgyor Payment System
SMTP_FROM_NAME=Vibgyor Payment System

# CUSTOMER_PORTAL_URL - URL to your customer portal (used in email links)
# Development: http://localhost:4200/customer-portal
# Production: https://yourdomain.com/customer-portal
CUSTOMER_PORTAL_URL=http://localhost:4200/customer-portal


# =============================================================================
# Company Details (for Invoices)
# =============================================================================
# These details appear on generated PDF invoices

# COMPANY_GST - Your company's GST number
# Example: 29XXXXX1234X1ZX
COMPANY_GST=29XXXXX1234X1ZX

# COMPANY_EMAIL - Your company's billing/support email
# Example: billing@vibgyor.com
COMPANY_EMAIL=billing@vibgyor.com

# COMPANY_PHONE - Your company's contact phone number
# Example: +91 1234567890
COMPANY_PHONE=+91 1234567890
